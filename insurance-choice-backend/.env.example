# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.
#
# For local development, export these variables in your shell or set them
# in your IDE's run configuration before starting the Spring Boot app.
#
# For Cloud Run, set these via:
#   gcloud run deploy ... --set-env-vars KEY=VALUE

# ── PostgreSQL (Cloud SQL) ────────────────────────────────────────────────────
DB_HOST=<cloud-sql-public-ip-or-hostname>
DB_NAME=<database-name>
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a long random Base64 string (at least 256 bits / 32 bytes).
# Generate with: openssl rand -base64 48
JWT_SECRET=<generate-a-strong-random-base64-secret>
